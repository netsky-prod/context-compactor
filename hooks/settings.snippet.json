{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "manual",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PROJECT_DIR}/hooks/precompact_telemetry.py", "timeout": 60 }
        ]
      },
      {
        "matcher": "auto",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PROJECT_DIR}/hooks/precompact_telemetry.py", "timeout": 60 }
        ]
      }
    ]
  }
}
